        {
            "operation": "copy",
            "source": "${git}/src/env",
            "destination": "source/env",
            "recursive": true,
            "replace": [
                {
                    "file": "source/env/__libc_start_main.c",
                    "replacements": [
                        [
                            "// weak_alias(libc_start_init, __libc_start_init);",
                            "weak_alias(libc_start_init, __libc_start_init);"
                        ],
                        [
                            "int __libc_start_main(int (*main)(int,char **,char **), int argc, char **argv,\n\tvoid (*init_dummy)(), void(*fini_dummy)(), void(*ldso_dummy)())\n{",
                            "static void (*g_init_dummy)();\nint __libc_start_main(int (*main)(int,char **,char **), int argc, char **argv,\n\tvoid (*init_dummy)(), void(*fini_dummy)(), void(*ldso_dummy)())\n{\n\tg_init_dummy = init_dummy;"
                        ],
                        [
                            "__libc_start_init();",
                            "if (g_init_dummy) g_init_dummy(); else __libc_start_init();"
                        ]
                    ]
                },
                {
                    "file": "source/env/__init_tls.c",
                    "replacements": [
                        [
                            "extern weak hidden const size_t _DYNAMIC[];",
                            "extern weak hidden const size_t _DYNAMIC[];\nextern weak const size_t __tls_modules[];"
                        ],
                        [
                            "static void static_init_tls(size_t *aux)\n{\n\tunsigned char *p;\n\tsize_t n;\n\tPhdr *phdr, *tls_phdr=0;\n\tsize_t base = 0;\n\tvoid *mem;\n\n\tfor (p=(void *)aux[AT_PHDR],n=aux[AT_PHNUM]; n; n--,p+=aux[AT_PHENT]) {",
                            "static void static_init_tls(size_t *aux)\n{\n\tunsigned char *p;\n\tsize_t n;\n\tPhdr *phdr, *tls_phdr=0;\n\tsize_t base = 0;\n\tvoid *mem;\n\tstatic struct tls_module library_tls_modules[32];\n\n\tif (__tls_modules) {\n\t\tsize_t cnt = __tls_modules[0];\n\t\tif (cnt > 32) cnt = 32;\n\t\tlibc.tls_cnt = cnt;\n\t\tstruct tls_module *prev = 0;\n\t\tfor (size_t i = 0; i < cnt; i++) {\n\t\t\tstruct tls_module *m = &library_tls_modules[i];\n\t\t\tm->image = (void *)__tls_modules[1 + 4*i];\n\t\t\tm->len = __tls_modules[2 + 4*i];\n\t\t\tm->size = __tls_modules[3 + 4*i];\n\t\t\tm->align = __tls_modules[4 + 4*i];\n\t\t\tm->next = 0;\n\t\t\tif (prev) {\n\t\t\t\tprev->next = m;\n\t\t\t} else {\n\t\t\t\tlibc.tls_head = m;\n\t\t\t}\n\t\t\tprev = m;\n\t\t}\n\t} else {\n\t\tfor (p=(void *)aux[AT_PHDR],n=aux[AT_PHNUM]; n; n--,p+=aux[AT_PHENT]) {"
                        ],
                        [
                            "\tif (tls_phdr) {\n\t\tmain_tls.image = (void *)(base + tls_phdr->p_vaddr);\n\t\tmain_tls.len = tls_phdr->p_filesz;\n\t\tmain_tls.size = tls_phdr->p_memsz;\n\t\tmain_tls.align = tls_phdr->p_align;\n\t\tlibc.tls_cnt = 1;\n\t\tlibc.tls_head = &main_tls;\n\t}\n\n\tmain_tls.size += (-main_tls.size - (uintptr_t)main_tls.image)\n\t\t& (main_tls.align-1);\n#ifdef TLS_ABOVE_TP\n\tmain_tls.offset = GAP_ABOVE_TP;\n\tmain_tls.offset += (-GAP_ABOVE_TP + (uintptr_t)main_tls.image)\n\t\t& (main_tls.align-1);\n#else\n\tmain_tls.offset = main_tls.size;\n#endif\n\tif (main_tls.align < MIN_TLS_ALIGN) main_tls.align = MIN_TLS_ALIGN;\n\n\tlibc.tls_align = main_tls.align;\n\tlibc.tls_size = 2*sizeof(void *) + sizeof(struct pthread)\n#ifdef TLS_ABOVE_TP\n\t\t+ main_tls.offset\n#endif\n\t\t+ main_tls.size + main_tls.align\n\t\t+ MIN_TLS_ALIGN-1 & -MIN_TLS_ALIGN;",
                            "\tif (tls_phdr) {\n\t\tmain_tls.image = (void *)(base + tls_phdr->p_vaddr);\n\t\tmain_tls.len = tls_phdr->p_filesz;\n\t\tmain_tls.size = tls_phdr->p_memsz;\n\t\tmain_tls.align = tls_phdr->p_align;\n\t\tlibc.tls_cnt = 1;\n\t\tlibc.tls_head = &main_tls;\n\t}\n\t}\n\n\tsize_t current_offset = 0;\n\tsize_t max_align = MIN_TLS_ALIGN;\n\tfor (struct tls_module *m = libc.tls_head; m; m = m->next) {\n\t\t// if (m->align < MIN_TLS_ALIGN) m->align = MIN_TLS_ALIGN;\n\t\tif (m->align > max_align) max_align = m->align;\n\n#ifdef TLS_ABOVE_TP\n\t\tif (m == libc.tls_head) {\n\t\t\tm->offset = GAP_ABOVE_TP + (-GAP_ABOVE_TP + (uintptr_t)m->image) & (m->align-1);\n\t\t} else {\n\t\t\tm->offset = (current_offset + m->size + m->align - 1) & -m->align;\n\t\t}\n#else\n\t\tif (m == libc.tls_head && !__tls_modules) {\n\t\t\tm->size += (-m->size - (uintptr_t)m->image) & (m->align-1);\n\t\t\tm->offset = m->size;\n\t\t} else {\n\t\t\tm->offset = (current_offset + m->size + m->align - 1) & -m->align;\n\t\t}\n#endif\n\t\tcurrent_offset = m->offset;\n\t}\n\n\tlibc.tls_align = max_align;\n\tlibc.tls_size = 2*sizeof(void *) + sizeof(struct pthread)\n\t\t+ current_offset + libc.tls_align\n\t\t+ MIN_TLS_ALIGN-1 & -MIN_TLS_ALIGN;"
                        ]
                    ]
                }
            ]
