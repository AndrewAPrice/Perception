{
    "repositories": [
        {
            "url": "https://github.com/netsurf-browser/libcss.git",
            "type": "git",
            "placeholder": "git"
        }
    ],
    "operations": [
        {
            "operation": "execute",
            "command": "python3 ${@}/generate_properties.py ${git}",
            "inputs": [
                "${@}/generate_properties.py",
                "${git}/src/parse/properties/css_property_parser_gen.c",
                "${git}/src/parse/properties/properties.gen"
            ],
            "outputs": [
                "${git}/src/parse/properties/autogenerated_color.c"
            ]
        },
        {
            "operation": "copy",
            "source": "${git}/src",
            "destination": "source",
            "recursive": true
        },
        {
            "operation": "copy",
            "source": "${git}/include/libcss",
            "destination": "public/libcss",
            "recursive": true
        }
    ]
}