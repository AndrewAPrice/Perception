{
    "repositories": [
        {
            "url": "https://github.com/libjpeg-turbo/libjpeg-turbo.git",
            "type": "git",
            "placeholder": "git"
        }
    ],
    "operations": [
        {
            "operation": "readRegExFromFile",
            "file": "${git}/CMakeLists.txt",
            "values": {
                ",major,minor,revision": "set\\(VERSION (\\d+).(\\d+).(\\d+)\\)"
            }
        },
        {
            "operation": "set",
            "values": {
                "8_bit_files_to_duplicate": [],
                "12_bit_files_to_duplicate": [
                    "jcapistd",
                    "jccoefct",
                    "jccolor",
                    "jcdctmgr",
                    "jcdiffct",
                    "jclossls",
                    "jcmainct",
                    "jcprepct",
                    "jcsample",
                    "jdapistd",
                    "jdcoefct",
                    "jdcolor",
                    "jddctmgr",
                    "jddiffct",
                    "jdlossls",
                    "jdmainct",
                    "jdmerge",
                    "jdpostct",
                    "jdsample",
                    "jfdctfst",
                    "jfdctint",
                    "jidctflt",
                    "jidctfst",
                    "jidctint",
                    "jidctred",
                    "jquant1",
                    "jquant2",
                    "jutils",
                    "rdppm",
                    "wrppm"
                ],
                "16_bit_files_to_duplicate": [
                    "jcapistd",
                    "jccolor",
                    "jcdiffct",
                    "jclossls",
                    "jcmainct",
                    "jcprepct",
                    "jcsample",
                    "jdapistd",
                    "jdcolor",
                    "jddiffct",
                    "jdlossls",
                    "jdmainct",
                    "jdpostct",
                    "jdsample",
                    "jquant1",
                    "jquant2",
                    "jutils",
                    "rdppm",
                    "wrppm"
                ]
            }
        },
        {
            "operation": "set",
            "values": {
                "8_bit_sources": "${git}/src/${8_bit_files_to_duplicate}.c",
                "8_bit_destinations": "${@}/source/${8_bit_files_to_duplicate}_12.c",
                "12_bit_sources": "${git}/src/${12_bit_files_to_duplicate}.c",
                "12_bit_destinations": "${@}/source/${12_bit_files_to_duplicate}_12.c",
                "16_bit_sources": "${git}/src/${16_bit_files_to_duplicate}.c",
                "16_bit_destinations": "${@}/source/${16_bit_files_to_duplicate}_16.c"
            }
        },
        {
            "operation": "evaluate",
            "values": {
                "version_string": "'${major}'+'.'+'${minor}'+'.'+'${revision}'",
                "version_number": "${major} * 100000 + ${minor} * 100 + ${revision}"
            }
        },
        {
            "operation": "readFilesInDirectory",
            "path": "${git}/src",
            "placeholder": "test-sources",
            "regex": "^tj.*\\.c",
            "fullPath": true,
            "replacements": [
                [
                    "${git}/src/",
                    "${@}/source/"
                ]
            ]
        },
        {
            "operation": "copy",
            "source": "${git}/src",
            "destination": "source",
            "extensions": [
                ".asm",
                ".c",
                ".cpp",
                ".h",
                ".hh",
                ".inc"
            ],
            "exclude": [
                "source/jerror.h",
                "source/jpeglib.h",
                "source/jmorecfg.h",
                "source/turbojpeg-jni.c",
                "${test-sources}"
            ],
            "replace": [
                {
                    "file": "source/jcapimin.c",
                    "replacements": [
                        [
                            "#include \"../simd/",
                            "#include \"simd/"
                        ]
                    ]
                },
                {
                    "file": "source/jccolor.c",
                    "replacements": [
                        [
                            "#include \"../simd/",
                            "#include \"simd/"
                        ]
                    ]
                },
                {
                    "file": "source/jchuff.c",
                    "replacements": [
                        [
                            "#include \"../simd/",
                            "#include \"simd/"
                        ]
                    ]
                },
                {
                    "file": "source/jcdctmgr.c",
                    "replacements": [
                        [
                            "#include \"../simd/",
                            "#include \"simd/"
                        ]
                    ]
                },
                {
                    "file": "source/jcphuff.c",
                    "replacements": [
                        [
                            "#include \"../simd/",
                            "#include \"simd/"
                        ]
                    ]
                },
                {
                    "file": "source/jcsample.c",
                    "replacements": [
                        [
                            "#include \"../simd/",
                            "#include \"simd/"
                        ]
                    ]
                },
                {
                    "file": "source/jdapimin.c",
                    "replacements": [
                        [
                            "#include \"../simd/",
                            "#include \"simd/"
                        ]
                    ]
                },
                {
                    "file": "source/jdcolor.c",
                    "replacements": [
                        [
                            "#include \"../simd/",
                            "#include \"simd/"
                        ]
                    ]
                },
                {
                    "file": "source/jdcolor.c",
                    "replacements": [
                        [
                            "#include \"../simd/",
                            "#include \"simd/"
                        ]
                    ]
                },
                {
                    "file": "source/jddctmgr.c",
                    "replacements": [
                        [
                            "#include \"../simd/",
                            "#include \"simd/"
                        ]
                    ]
                },
                {
                    "file": "source/jdmerge.c",
                    "replacements": [
                        [
                            "#include \"../simd/",
                            "#include \"simd/"
                        ]
                    ]
                },
                {
                    "file": "source/jdsample.c",
                    "replacements": [
                        [
                            "#include \"../simd/",
                            "#include \"simd/"
                        ]
                    ]
                },
                {
                    "file": "source/jpeg_nbits.c",
                    "replacements": [
                        [
                            "#include \"../simd/",
                            "#include \"simd/"
                        ]
                    ]
                },
                {
                    "file": "source/rdpng.c",
                    "replacements": [
                        [
                            "#include \"spng/spng.h\"",
                            "#include \"spng.h\""
                        ]
                    ]
                },
                {
                    "file": "source/wrpng.c",
                    "replacements": [
                        [
                            "#include \"spng/spng.h\"",
                            "#include \"spng.h\""
                        ]
                    ]
                }
            ]
        },
        {
            "operation": "copy",
            "source": "${12_bit_sources}",
            "destination": "${12_bit_destinations}",
            "replace": [
                {
                    "file": "${12_bit_destinations}",
                    "prepend": "#define BITS_IN_JSAMPLE 12\n"
                }
            ]
        },
        {
            "operation": "copy",
            "source": "${8_bit_sources}",
            "destination": "${8_bit_destinations}",
            "replace": [
                {
                    "file": "${8_bit_destinations}",
                    "prepend": "#define BITS_IN_JSAMPLE 8\n"
                }
            ]
        },
        {
            "operation": "copy",
            "source": "${16_bit_sources}",
            "destination": "${16_bit_destinations}",
            "replace": [
                {
                    "file": "${16_bit_destinations}",
                    "prepend": "#define BITS_IN_JSAMPLE 16\n"
                }
            ]
        },
        {
            "operation": "copy",
            "source": "${git}/simd",
            "destination": "source/simd",
            "extensions": [
                ".asm",
                ".c",
                ".cpp",
                ".h",
                ".hh",
                ".inc"
            ],
            "replace": [
                {
                    "file": "source/simd/jsimddct.h",
                    "replacements": [
                        [
                            "#include \"../src/jdct.h\"",
                            "#include \"jdct.h\""
                        ]
                    ]
                },
                {
                    "file": "source/simd/jsimd.h",
                    "replacements": [
                        [
                            "#include \"../src/jchuff.h\"",
                            "#include \"jchuff.h\""
                        ]
                    ]
                },
                {
                    "file": "source/simd/jsimdint.h",
                    "replacements": [
                        [
                            "#include \"../src/jdct.h\"",
                            "#include \"jdct.h\""
                        ],
                        [
                            "#include \"../src/jchuff.h\"",
                            "#include \"jchuff.h\""
                        ]
                    ]
                },
                {
                    "file": "source/simd/simdconverage.h",
                    "replacements": [
                        [
                            "#include \"../src/jpegapicomp.h\"",
                            "#include \"jpegapicomp.h\""
                        ]
                    ]
                }
            ]
        },
        {
            "operation": "copy",
            "source": "${git}/simd/x86_64",
            "destination": "source/simd/x86_64",
            "extensions": [
                ".asm",
                ".c",
                ".cpp",
                ".h",
                ".hh",
                ".inc"
            ],
            "exclude": [
                "source/simd/x86_64/jsimdcfg.inc.h"
            ],
            "replace": [
                {
                    "file": "source/simd/x86_64/jsimd.c",
                    "replacements": [
                        [
                            "#include \"../../src/jpeglib.h\"",
                            "#include \"jpeglib.h\""
                        ],
                        [
                            "#include \"../../src/",
                            "#include \"../../"
                        ]
                    ]
                }
            ]
        },
        {
            "operation": "copy",
            "source": "${git}/simd/nasm",
            "destination": "source/simd/x86_64",
            "extensions": [
                ".asm",
                ".c",
                ".cpp",
                ".h",
                ".hh",
                ".inc"
            ],
            "replace": [
                {
                    "file": "source/simd/x86_64/jsimdext.inc",
                    "replacements": [
                        [
                            ";  System-dependent configurations",
                            ";  System-dependent configurations\n%define __x86_64__\n%define ELF\n"
                        ]
                    ]
                }
            ]
        },
        {
            "operation": "copy",
            "source": "${git}/src/md5",
            "destination": "source/md5",
            "extensions": [
                ".asm",
                ".c",
                ".cpp",
                ".h",
                ".hh",
                ".inc"
            ],
            "exclude": [
                "source/md5/md5cmp.c",
                "source/md5/md5sum.c"
            ]
        },
        {
            "operation": "copy",
            "source": "${git}/src/jconfig.h.in",
            "destination": "public/jconfig.h",
            "replace": [
                {
                    "file": "public/jconfig.h",
                    "replacements": [
                        [
                            "@VERSION@",
                            "\"${version_string}\""
                        ],
                        [
                            "@LIBJPEG_TURBO_VERSION_NUMBER@",
                            "${version_number}"
                        ],
                        [
                            "@JPEG_LIB_VERSION@",
                            "80"
                        ],
                        [
                            "#cmakedefine RIGHT_SHIFT_IS_UNSIGNED 1",
                            ""
                        ],
                        [
                            "#cmakedefine",
                            "#define"
                        ],
                        [
                            "@BITS_IN_JSAMPLE@",
                            "12"
                        ]
                    ]
                }
            ]
        },
        {
            "operation": "copy",
            "source": "${git}/src/jerror.h",
            "destination": "public/jerror.h"
        },
        {
            "operation": "copy",
            "source": "${git}/src/jpeglib.h",
            "destination": "public/jpeglib.h"
        },
        {
            "operation": "copy",
            "source": "${git}/src/jmorecfg.h",
            "destination": "public/jmorecfg.h"
        },
        {
            "operation": "copy",
            "source": "${git}/src/jconfigint.h.in",
            "destination": "source/jconfigint.h",
            "replace": [
                {
                    "file": "source/jconfigint.h",
                    "replacements": [
                        [
                            "@BUILD@",
                            "0"
                        ],
                        [
                            "@INLINE@",
                            "__inline__ __attribute__((always_inline))"
                        ],
                        [
                            "@THREAD_LOCAL@",
                            "__thread"
                        ],
                        [
                            "@CMAKE_PROJECT_NAME@",
                            "turbo-jpeg"
                        ],
                        [
                            "@HIDDEN@",
                            ""
                        ],
                        [
                            "@SIMD_ARCHITECTURE@",
                            "X86_64"
                        ],
                        [
                            "@VERSION@",
                            "${version_string}"
                        ],
                        [
                            "@SIZE_T@",
                            "8"
                        ],
                        [
                            "#cmakedefine",
                            "#define"
                        ],
                        [
                            "#define HAVE_INTRIN_H",
                            ""
                        ]
                    ]
                }
            ]
        },
        {
            "operation": "copy",
            "source": "${git}/src/jversion.h.in",
            "destination": "source/jversion.h"
        },
        {
            "operation": "copy",
            "source": "${git}/simd/nasm/jsimdcfg.inc.h",
            "destination": "source/simd/jsimdcfg.inc.h",
            "replace": [
                {
                    "file": "source/simd/jsimdcfg.inc.h",
                    "replacements": [
                        [
                            "#include \"../../src/jpeglib.h\"",
                            "#include \"jpeglib.h\""
                        ],
                        [
                            "#include \"../jconfig.h\"",
                            "#include \"jconfig.h\""
                        ],
                        [
                            "#include \"../src/jmorecfg.h\"",
                            "#include \"jmorecfg.h\""
                        ],
                        [
                            "#include \"../jsimdconst.h\"",
                            "#include \"jsimdconst.h\""
                        ]
                    ]
                }
            ]
        },
        {
            "operation": "execute",
            "command": "gcc -I ${@}/public -I ${@}/source -E -P ${@}/source/simd/jsimdcfg.inc.h | grep -E '^[\\;%]|^\\ %' | sed 's%_cpp_protection_%%' | sed 's@% define@%define@g' > ${@}/source/simd/x86_64/jsimdcfg.inc",
            "inputs": [
                "source/simd/jsimdcfg.inc.h"
            ],
            "outputs": [
                "source/simd/x86_64/jsimdcfg.inc"
            ]
        }
    ]
}