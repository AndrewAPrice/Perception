{
    "repositories": [
        {
            "url": "-b SDL2 https://github.com/libsdl-org/SDL_mixer.git",
            "type": "git",
            "placeholder": "git"
        }
    ],
    "operations": [
        {
            "operation": "copy",
            "source": "${git}/include/SDL_mixer.h",
            "destination": "public/SDL_mixer.h"
        },
        {
            "operation": "copy",
            "source": "${git}/src",
            "destination": "source",
            "recursive": true,
            "extensions": [
                ".c",
                ".h"
            ],
            "exclude": [
                "source/playmus.c",
                "source/playwave.c"
            ]
        }
    ]
}