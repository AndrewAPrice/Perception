{
    "repositories": [
        {
            "url": "https://github.com/netsurf-browser/libsvgtiny.git",
            "type": "git",
            "placeholder": "git"
        }
    ],
    "operations": [
        {
            "operation": "execute",
            "command": "cd ${git} && gperf src/colors.gperf | sed -e 's/^\\(const struct svgtiny_named_color\\)/static \\1/' > src/autogenerated_colors.c",
            "inputs": [
                "${git}/src/colors.gperf"
            ],
            "outputs": [
                "${git}/src/autogenerated_colors.c"
            ]
        },
        {
            "operation": "copy",
            "source": "${git}/src",
            "destination": "source",
            "recursive": true
        },
        {
            "operation": "copy",
            "source": "${git}/src/autogenerated_colors.c",
            "destination": "source/autogenerated_colors.c"
        },
        {
            "operation": "copy",
            "source": "${git}/include/svgtiny.h",
            "destination": "public/svgtiny.h"
        }
    ]
}
