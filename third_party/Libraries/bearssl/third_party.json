{
    "repositories": [
        {
            "url": "https://www.bearssl.org/git/BearSSL",
            "type": "git",
            "placeholder": "git"
        }
    ],
    "operations": [
        {
            "operation": "copy",
            "source": "${git}/src",
            "destination": "source",
            "recursive": true
        },
        {
            "operation": "copy",
            "source": "${git}/inc",
            "destination": "public",
            "recursive": true
        }
    ]
}
