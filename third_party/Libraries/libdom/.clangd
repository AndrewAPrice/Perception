CompileFlags:
  Add: [
    "-I/Users/andrewaprice/Documents/GitHub/Perception/third_party/Libraries/libcxx/public",
    "-I/Users/andrewaprice/Documents/GitHub/Perception/third_party/Libraries/musl/include",
    "-I/Users/andrewaprice/Documents/GitHub/Perception/third_party/Libraries/libdom/source",
    "-I/Users/andrewaprice/Documents/GitHub/Perception/third_party/Libraries/libdom/public",
    "-I/Users/andrewaprice/Documents/GitHub/Perception/third_party/Libraries/libparserutils/public",
    "-I/Users/andrewaprice/Documents/GitHub/Perception/third_party/Libraries/libwapcaplet/public",
    "-I/Users/andrewaprice/Documents/GitHub/Perception/third_party/Libraries/libhubbub/public",
    "-I/Users/andrewaprice/Documents/GitHub/Perception/third_party/Libraries/gnome libxml2/public",
    "-I/Users/andrewaprice/Documents/GitHub/Perception/Libraries/perception/public",
    "-I/Users/andrewaprice/Documents/GitHub/Perception/Libraries/Linux System Call Shim/public",
    "-I/Users/andrewaprice/Documents/GitHub/Perception/third_party/Libraries/madler zlib/public",
    "-I/Users/andrewaprice/Documents/GitHub/Perception/third_party/Libraries/unicode-org icu/public",
    "-I/Users/andrewaprice/Documents/GitHub/Perception/third_party/Libraries/harfbuzz icu-le-hb/public",
    "-I/Users/andrewaprice/Documents/GitHub/Perception/third_party/Libraries/harfbuzz/public",
    "-I/Users/andrewaprice/Documents/GitHub/Perception/third_party/Libraries/freetype/public",
    -DLIBCXXRT,
    -DLIBC_NAMESPACE=__llvm_libc,
    -DPERCEPTION,
    -D_GNU_SOURCE,
    -D_LIBCPP_ASSERTION_SEMANTIC_DEFAULT=4,
    -D_LIBCPP_HARDENING_MODE=2,
    -D_LIBCPP_HAS_FILESYSTEM,
    -D_LIBCPP_HAS_LOCALIZATION,
    -D_LIBCPP_HAS_MONOTONIC_CLOCK,
    -D_LIBCPP_HAS_MUSL_LIBC,
    -D_LIBCPP_HAS_RANDOM_DEVICE,
    -D_LIBCPP_HAS_THREADS,
    -D_LIBCPP_HAS_THREAD_API_C11,
    -D_LIBCPP_HAS_THREAD_API_PTHREAD,
    -D_LIBCPP_HAS_TIME_ZONE_DATABASE,
    -D_LIBCPP_PSTL_BACKEND_STD_THREAD,
    -Dfast_BUILD_,
    -g,
    -O2,
    -c,
    --target=x86_64-unknown-none-elf,
    -nostdinc,
    -mno-red-zone,
    -fdata-sections,
    -ffunction-sections,
    -fPIC,
    -isystem,
    -std=c++23,
    -nostdinc++,
    -MD,
    -MF,
    -o,
  ]
---
If:
  PathMatch: .*\.c
CompileFlags:
  Add: [
    -g,
    -O2,
    -c,
    --target=x86_64-unknown-none-elf,
    -nostdinc,
    -mno-red-zone,
    -fdata-sections,
    -ffunction-sections,
    -fPIC,
    -isystem,
    -std=c17,
    -MD,
    -MF,
    -o,
  ]
