{
  skip_for_tests: true,
  package_type: 'library',
  defines+: [
    'SDL_DYNAMIC_API=0',
  ],
  dependencies+: [
    'musl',
    'libcxx',
    'perception',
    'Perception UI',
    'Perception Window',
  ],
