    'source/core/linux/SDL_sandbox.c',
    'source/render/direct3d11/SDL_render_d3d11.c',
    'source/render/direct3d11/SDL_shaders_d3d11.c',
    'source/render/ps2/SDL_render_ps2.c',
    'source/render/psp/SDL_render_psp.c',
    'source/render/direct3d12/SDL_render_d3d12.c',
    'source/render/direct3d12/SDL_shaders_d3d12.c',
    'source/render/vitagxm/SDL_render_vita_gxm.c',
    'source/render/vitagxm/SDL_render_vita_gxm_memory.c',
    'source/render/vitagxm/SDL_render_vita_gxm_tools.c',
    'source/render/opengles/SDL_render_gles.c',
    'source/render/opengles2/SDL_render_gles2.c',
    'source/render/opengles2/SDL_shaders_gles2.c',
    'source/render/direct3d/SDL_shaders_d3d.c',
    'source/render/direct3d/SDL_render_d3d.c',
    'source/render/opengl/SDL_render_gl.c',
    'source/render/opengl/SDL_shaders_gl.c',
    'source/sensor/SDL_sensor.c',
    'source/haptic/SDL_haptic.c',
    'source/joystick/SDL_joystick.c',
    'source/joystick/SDL_steam_virtual_gamepad.c',
