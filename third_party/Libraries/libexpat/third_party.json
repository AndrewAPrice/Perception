{
    "repositories" : [
        {
            "url": "https://github.com/libexpat/libexpat.git",
            "type": "git",
            "placeholder": "git"
        }
    ],
    "operations" : [
        {
            "operation": "copy",
            "source": "${git}/expat/lib",
            "destination": "source",
            "extensions": [".c"],
            "exclude": [
                "${@}/source/random_arc4random.c",
                "${@}/source/random_arc4random_buf.c",
                "${@}/source/random_getentropy.c",
                "${@}/source/random_getrandom.c",
                "${@}/source/random_rand_s.c"
            ]
        },
        {
            "operation": "copy",
            "source": "${git}/expat/lib",
            "destination": "public",
            "extensions": [".h"]
        },
        {
            "operation": "execute",
            "command": "echo '#define XML_CONTEXT_BYTES 1024\n#define XML_DTD 1\n#define XML_NS 1\n#define XML_GE 1\n#define BYTEORDER 1234\n#define HAVE_MEMMOVE 1\n#define XML_DEV_URANDOM 1' > ${@}/public/expat_config.h",
            "outputs": ["public/expat_config.h"]
        }
    ]
}
