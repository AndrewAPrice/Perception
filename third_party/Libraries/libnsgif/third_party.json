{
    "repositories": [
        {
            "url": "https://github.com/netsurf-browser/libnsgif.git",
            "type": "git",
            "placeholder": "git"
        }
    ],
    "operations": [
        {
            "operation": "copy",
            "source": "${git}/src",
            "destination": "source",
            "recursive": true
        },
        {
            "operation": "copy",
            "source": "${git}/include/nsgif.h",
            "destination": "public/nsgif.h"
        }
    ]
}
