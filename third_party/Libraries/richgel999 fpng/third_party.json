{
    "repositories" : [
        {
            "url": "https://github.com/richgel999/fpng.git",
            "type": "git",
            "placeholder": "git"
        }
    ],
    "operations" : [
        {
            "operation": "copy",
            "source": "${git}/src",
            "destination": "source",
            "exclude": [
                "source/fpng_test.cpp"
            ],
            "extensions": [".cpp"]
        },
        {
            "operation": "copy",
            "source": "${git}/src/",
            "destination": "public",
            "extensions": [".h"]
        }
    ]
}