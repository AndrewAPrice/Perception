{
    "repositories" : [
        {
            "url": "https://github.com/unicode-org/icu/releases/download/release-72-1/icu4c-72_1-src.zip",
            "type": "zip",
            "placeholder": "zip"
        }
    ],
    "operations" : [
        {
            "operation": "copy",
            "source": "${zip}/icu/source/common/",
            "destination": "source/common"
        },
        {
            "operation": "copy",
            "source": "${zip}/icu/source/common/unicode",
            "destination": "public/unicode",
            "extension": [".h"]
        },
        {
            "operation": "copy",
            "source": "${zip}/icu/source/i18n",
            "destination": "source/common"
        },
        {
            "operation": "copy",
            "source": "${zip}/icu/source/i18n/unicode",
            "destination": "public/unicode",
            "extensions": [".h"]
        },
        {
            "operation": "copy",
            "source": "${zip}/icu/source/layoutex",
            "destination": "source/common"
        },
        {
            "operation": "copy",
            "source": "${zip}/icu/source/layoutex/layout",
            "destination": "public/layout",
            "extensions": [".h"]
        },
        {
            "operation": "copy",
            "source": "${zip}/icu/source/stubdata",
            "destination": "source/stubdata"
        },
        {
            "operation": "copy",
            "source": "third_party/icudt72l.dat",
            "destination": "assets/icudt72l.dat"
        }
    ]
}