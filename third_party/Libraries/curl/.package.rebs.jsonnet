{
  skip_for_tests: true,
  package_type: 'library',
  dependencies+: [
    'musl',
    'bearssl',
    'madler zlib',
  ],
  public_include_directories: [
    'public',
  ],
  include_directories: [
    'config',
    'source',
    'public',
  ],
  source_directories: [
    'source',
  ],
  defines+: [
    'HAVE_CONFIG_H',
    'BUILDING_LIBCURL',
    'CURL_STATICLIB',
    'CURL_DISABLE_LDAP',
    'CURL_DISABLE_LDAPS',
    'CURL_DISABLE_TELNET',
    'CURL_DISABLE_DICT',
    'CURL_DISABLE_TFTP',
    'CURL_DISABLE_SMB',
    'CURL_DISABLE_POP3',
    'CURL_DISABLE_IMAP',
    'CURL_DISABLE_SMTP',
    'CURL_DISABLE_RTSP',
    'USE_BEARSSL',
    'HAVE_SOCKET',
    'HAVE_SELECT',
    'HAVE_POLL',
    'HAVE_UNISTD_H',
    'HAVE_SYS_SOCKET_H',
    'HAVE_NETINET_IN_H',
    'HAVE_ARPA_INET_H',
    'HAVE_NETDB_H',
    'HAVE_FCNTL_O_NONBLOCK',
    'HAVE_ZLIB_H',
  ],
}
