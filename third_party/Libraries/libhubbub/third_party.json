{
    "repositories": [
        {
            "url": "https://github.com/netsurf-browser/libhubbub.git",
            "type": "git",
            "placeholder": "git"
        }
    ],
    "operations": [
        {
            "operation": "execute",
            "command": "cd ${git} && perl build/make-entities.pl && gperf src/treebuilder/element-type.gperf | sed -e 's/^\\(const struct element_type_map\\)/static \\1/' > src/treebuilder/autogenerated-element-type.c",
            "inputs": [
                "${git}/build/make-entities.pl",
                "${git}/build/Entities",
                "${git}/src/treebuilder/element-type.gperf"
            ],
            "outputs": [
                "${git}/src/tokeniser/entities.inc",
                "${git}/src/treebuilder/autogenerated-element-type.c"
            ]
        },
        {
            "operation": "copy",
            "source": "${git}/src",
            "destination": "source",
            "recursive": true
        },
        {
            "operation": "copy",
            "source": "${git}/src/tokeniser/entities.inc",
            "destination": "source/tokeniser/entities.inc"
        },
        {
            "operation": "copy",
            "source": "${git}/src/treebuilder/autogenerated-element-type.c",
            "destination": "source/treebuilder/autogenerated-element-type.c"
        },
        {
            "operation": "copy",
            "source": "${git}/include/hubbub",
            "destination": "public/hubbub",
            "recursive": true
        }
    ]
}
