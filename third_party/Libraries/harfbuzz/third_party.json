{
    "repositories" : [
        {
            "url": "https://github.com/harfbuzz/harfbuzz.git",
            "type": "git",
            "placeholder": "git"
        }
    ],
    "operations" : [
        {
            "operation": "copy",
            "source": "${git}/src",
            "destination": "public",
            "extension": [".h", ".hh"]
        },
        {
            "operation": "readFilesInDirectory",
            "path": "${git}/src",
            "placeholder": "test-sources",
            "regex": "^test.*\\.cc$",
            "fullPath": true,
            "replacements": [["${git}/src/", "${@}/source/"]]
        },
        {
            "operation": "copy",
            "source": "${git}/src",
            "destination": "source",
            "extension": [".c", ".cc"],
            "exclude": [
                "source/harfbuzz.cc",
                "source/harfbuzz-subset.cc",
                "source/main.cc",
                "${test-sources}"
            ]
        },
        {
            "operation": "copy",
            "source": "${git}/src/OT",
            "destination": "public/OT",
            "recursive": true
        },
        {
            "operation": "copy",
            "source": "${git}/src/graph",
            "destination": "public/graph",
            "exclude": ["public/graph/test-classdef-graph.cc"]
        }
    ]
}