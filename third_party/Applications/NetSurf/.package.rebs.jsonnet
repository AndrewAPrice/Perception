{
  skip_for_tests: true,
  package_type: 'application',
  dependencies+: [
    'libwapcaplet',
    'libparserutils',
    'libhubbub',
    'libdom',
    'libcss',
    'libnsbmp',
    'libnsgif',
    'libnsutils',
    'libnspsl',
    'libsvgtiny',
    'libjpeg-turbo',
    'libpng',
    'libwebp',
    'madler zlib',
    'perception',
    'Perception UI',
    'Perception Window',
    'bearssl',
  ],
  include_directories: [
    'source',
    'source/content/handlers',
    'source/content/handlers/javascript',
    'source/content/handlers/javascript/duktape/generated',
    'source/frontends',
    'public',
  ],
  source_directories: [
    'source/content',
    'source/desktop',
    'source/utils',
    'source/frontends/perception',
  ],
  files_to_ignore: [
    'source/content/handlers/image/rsvg.c',
    'source/content/handlers/image/rsvg246.c',
    'source/content/handlers/image/nssprite.c',
    'source/content/handlers/image/jpegxl.c',
    'source/content/handlers/image/video.c',
    'source/content/fetchers/curl.c',
    'source/content/handlers/javascript/none/none.c',
  ],
  asset_directories: [
    'assets',
  ],
  defines+: [
    'WITH_BMP',
    'WITH_GIF',
    'WITH_JPEG',
    'WITH_PNG',
    'WITH_WEBP',
    'WITH_NS_SVG',
    'NETSURF_HOMEPAGE="\\"about:welcome\\""',
    'NETSURF_LOG_LEVEL=DEEPDEBUG',
    'NETSURF_FB_RESPATH="\\"/Applications/netsurf/res\\""',
    'NETSURF_BUILTIN_LOG_FILTER="\\"\\""',
    'NETSURF_BUILTIN_VERBOSE_FILTER="\\"\\""',
    'NETSURF_FB_FONTPATH="\\"/Libraries/Fonts/assets/assets/\\""',
    'NETSURF_FB_FONT_SANS_SERIF="\\"DejaVuSans.ttf\\""',
    'NETSURF_FB_FONT_SANS_SERIF_BOLD="\\"DejaVuSans-Bold.ttf\\""',
    'NETSURF_FB_FONT_SANS_SERIF_ITALIC="\\"DejaVuSans-Oblique.ttf\\""',
    'NETSURF_FB_FONT_SANS_SERIF_ITALIC_BOLD="\\"DejaVuSans-BoldOblique.ttf\\""',
    'NETSURF_FB_FONT_SERIF="\\"DejaVuSerif.ttf\\""',
    'NETSURF_FB_FONT_SERIF_BOLD="\\"DejaVuSerif-Bold.ttf\\""',
    'NETSURF_FB_FONT_MONOSPACE="\\"DejaVuSansMono.ttf\\""',
    'NETSURF_FB_FONT_MONOSPACE_BOLD="\\"DejaVuSansMono-Bold.ttf\\""',
    'NETSURF_FB_FONT_CURSIVE="\\"DejaVuSans.ttf\\""',
    'NETSURF_FB_FONT_FANTASY="\\"DejaVuSans.ttf\\""',
  ],
}

