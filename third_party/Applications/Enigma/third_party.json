                            "std::string full_id = XMLtoLocal(systemId).c_str();\n        size_t slash_pos = full_id.find_last_of(\"/\\\\\");\n        std::string schemaName = (slash_pos == std::string::npos) ? full_id : full_id.substr(slash_pos + 1);"
